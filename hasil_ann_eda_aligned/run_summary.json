    "text_svd_components_requested": 96
  },
  "ridge_baseline": {
    "best_alpha": 300,
    "validation_metrics": {
      "rmse": 0.5685089673428353,
      "mae": 0.4545817281260635
    },
    "test_metrics": {
      "rmse": 0.610346677771169,
      "mae": 0.49722553166476163
    }
  },
  "best_ann_config": {
    "name": "ann_safe_01",
    "hidden_layers": [
      256,
      128
    ],
    "dropout": 0.05,
    "learning_rate": 0.001,
    "weight_decay": 1e-05,
    "batch_size": 64,
    "max_epochs": 160,
    "patience": 15,
    "use_batchnorm": true,
    "loss_name": "huber"
  },
  "best_ann_best_epoch": 4,
  "best_ann_validation_metrics": {
    "rmse": 0.5476029891641973,
    "mae": 0.43089438423965915
  },
  "best_ann_test_metrics": {
    "rmse": 0.5916285654374812,
    "mae": 0.4772300806912509
  },
  "note": "ANN ini mengikuti EDA: dedup train, drop fitur multikolinear, gunakan indikator sparse feature, one-hot untuk kategori low-cardinality, frequency encoding untuk kategori high-cardinality, dan TF-IDF char n-gram + SVD untuk nama produk."
}